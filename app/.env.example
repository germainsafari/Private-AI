# --- Base URL (OpenAI-compatible root for the OpenAI SDK) ---
# Local uvicorn: localhost + engine path below.
# Docker Compose with `models:` (see docker-compose.yml): OPENAI_BASE_URL is injected — omit here.
# Generic path: .../engines/v1 · engine-specific: .../engines/gemma4.cpp/v1
OPENAI_BASE_URL=http://localhost:12434/engines/gemma4.cpp/v1

# Model id as registered in DMR (often includes :tag).
MODEL_NAME=ai/gemma4:latest

# Optional. DMR ignores it; leave blank and the app uses a harmless placeholder so the SDK does not error.
API_KEY=
