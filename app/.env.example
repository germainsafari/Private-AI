# OpenAI-compatible base URL (must end in /v1).
# WSL vLLM published to the Windows host:
OPENAI_BASE_URL=http://127.0.0.1:8080/v1

# Model id exactly as your server reports it (GET $OPENAI_BASE_URL/models).
MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct

# Some servers ignore the API key; any non-empty value works.
API_KEY=not-needed
# VLLM_API_KEY=replace-with-a-long-random-secret

# Admission control (gateway-side)
MAX_CONCURRENCY=8
MAX_QUEUE_DEPTH=64
REQUEST_TIMEOUT_SECONDS=300
MAX_OUTPUT_TOKENS=4096

# Optional second backend for SLA-aware multi-model routing
# FAST_BASE_URL=http://127.0.0.1:8081/v1
# FAST_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
# FAST_MAX_CONCURRENCY=8
# SLA_TTFT_MS=1500

# Optional. Overrides the default assistant personality.
# SYSTEM_PROMPT=You are a helpful AI assistant.
